# =============================================
# WeatherOps — Configuration
# =============================================
# 1. Copiez ce fichier : cp .env.example .env
# 2. Remplissez votre clé API ci-dessous
# 3. Obtenez une clé GRATUITE sur : https://openweathermap.org/api
# =============================================

# Clé API OpenWeatherMap (remplacer par votre vraie clé)
OPENWEATHER_API_KEY=your_api_key_here

# Chemin base de données SQLite (ne pas modifier si Docker)
DB_PATH=/app/data/weatherops.db